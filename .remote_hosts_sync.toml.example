active_host = "production"

[[hosts]]
name = "production"
type = "sftp"
host = "example.com"
port = 22
user = "deploy"
ssh_key = "~/.ssh/id_rsa"
remote_path = "/var/www/project"
excludes_local = ["node_modules/", ".git/"]
excludes_remote = ["cache/", "logs/"]

[[hosts]]
name = "staging"
type = "rsync"
host = "staging.example.com"
port = 22
user = "deploy"
password_env = "STAGING_DEPLOY_PASSWORD"
remote_path = "/var/www/staging"
excludes_local = ["node_modules/", ".git/"]
excludes_remote = ["cache/"]
